{
  "name": "init-backend-project",
  "version": "1.0.6",
  "description": "Create production-ready Node.js, Express, Fastify, and NestJS backend starter projects with one CLI command.",
  "type": "module",
  "main": "./dist/cli.js",
  "types": "./dist/cli.d.ts",
  "bin": {
    "init-backend-project": "dist/cli.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "init-backend-project",
    "backend",
    "backend-starter",
    "backend-template",
    "backend-generator",
    "api-starter",
    "api-template",
    "node",
    "nodejs",
    "nodejs-starter",
    "nodejs-template",
    "cli",
    "scaffold",
    "scaffolding",
    "generator",
    "project-generator",
    "express",
    "express-starter",
    "express-template",
    "fastify",
    "fastify-starter",
    "fastify-template",
    "nestjs",
    "nestjs-starter",
    "nestjs-template",
    "typescript",
    "typescript-starter",
    "javascript",
    "rest-api",
    "api",
    "docker",
    "prisma",
    "typeorm",
    "mongoose"
  ],
  "author": "Choch Kimhour",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chochkimhour/init-backend-project.git"
  },
  "bugs": {
    "url": "https://github.com/chochkimhour/init-backend-project/issues"
  },
  "homepage": "https://www.npmjs.com/package/init-backend-project",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.3.2",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "execa": "^9.5.2",
    "fs-extra": "^11.3.0",
    "ora": "^8.2.0",
    "validate-npm-package-name": "^6.0.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.13.10",
    "@types/validate-npm-package-name": "^4.0.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
